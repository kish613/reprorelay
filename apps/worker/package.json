{
  "name": "@reprorelay/worker",
  "version": "0.1.0",
  "description": "ReproRelay GitHub sync and agent handoff worker.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/worker.ts",
    "lint": "eslint src",
    "start": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@reprorelay/agent-adapters": "0.1.0",
    "@reprorelay/github": "0.1.0",
    "@reprorelay/shared": "0.2.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2"
  }
}
