{
  "name": "@reprorelay/dashboard",
  "version": "0.1.0",
  "description": "ReproRelay triage dashboard.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build && node scripts/assert-live-bundle.mjs && node scripts/copy-sdk.mjs",
    "build:showcase": "tsc -p tsconfig.json && vite build --mode showcase",
    "dev": "vite --host 0.0.0.0",
    "dev:showcase": "vite --host 0.0.0.0 --mode showcase",
    "lint": "eslint src",
    "preview": "vite preview --host 0.0.0.0",
    "preview:showcase": "vite preview --host 0.0.0.0 --mode showcase",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@reprorelay/shared": "0.2.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "^8.1.4"
  }
}
