{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/worker/Dockerfile",
    "watchPatterns": [
      "/apps/worker/**",
      "/packages/agent-adapters/**",
      "/packages/github/**",
      "/packages/shared/**",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
