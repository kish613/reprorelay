# Shared
NODE_ENV=development
REPRORELAY_PUBLIC_URL=http://localhost:5173
REPRORELAY_API_URL=http://localhost:4000

# API
PORT=4000
DATABASE_URL=postgres://reprorelay:reprorelay@localhost:5432/reprorelay
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174
# Optional in development; set this allowlist in production so arbitrary project
# keys cannot mint report sessions.
REPRORELAY_PROJECT_KEYS=proj_demo-react,proj_client_app
# Optional project-scoped server keys for authenticated cross-browser status
# feeds. Keep these secrets on servers only; never expose them to widget code.
# REPRORELAY_STATUS_API_KEYS={"proj_client_app":"replace-with-at-least-32-random-characters"}
REPRORELAY_MAX_UPLOAD_BYTES=26214400
WEBHOOK_SECRET=replace-with-github-webhook-secret

# Required for the private operations dashboard. Generate independent random
# values for the password, session signing secret, and internal worker token.
REPRORELAY_ADMIN_PASSWORD=replace-with-a-strong-password
REPRORELAY_ADMIN_SESSION_SECRET=
REPRORELAY_INTERNAL_TOKEN=
REPRORELAY_ADMIN_SESSION_TTL_SECONDS=43200

# S3-compatible object storage
STORAGE_DRIVER=auto
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=reprorelay
S3_ACCESS_KEY_ID=reprorelay
S3_SECRET_ACCESS_KEY=reprorelay-secret
S3_FORCE_PATH_STYLE=true
# Optional direct asset base URL. Leave blank to proxy reads through the API.
S3_PUBLIC_URL=

# Vercel Blob object storage alternative
# STORAGE_DRIVER=vercel-blob
# VERCEL_BLOB_ACCESS=private
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=
# VERCEL_BLOB_UPLOAD_TTL_SECONDS=300
# VERCEL_BLOB_MAX_UPLOAD_BYTES=209715200
# VERCEL_BLOB_CACHE_CONTROL_MAX_AGE=2592000

# AI triage (OpenAI). When OPENAI_API_KEY is set, the worker generates the AI
# triage draft with OpenAI and falls back to the built-in local heuristic on any
# error. Leave blank to always use the local heuristic.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Reporter email replies (Resend). Both a key and a verified From address are
# required to enable the "Reply to reporter" action; otherwise the dashboard
# offers internal notes only.
RESEND_API_KEY= # gitleaks:allow -- intentionally blank example value
REPRORELAY_REPLY_FROM=ReproRelay <support@yourdomain.com>
# REPRORELAY_REPLY_REPLY_TO=support@yourdomain.com

# Evidence retention. Vercel Cron sends CRON_SECRET as a Bearer token to the
# daily cleanup route. Video evidence is deleted after seven days by default;
# screenshots and replay data remain attached to the report.
CRON_SECRET=
REPRORELAY_VIDEO_RETENTION_DAYS=7

# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_INSTALLATION_ID=
GITHUB_OWNER=
GITHUB_REPO=

# Agent handoff
AGENT_HANDOFF_MODE=triage
CLAUDE_TRIGGER=@claude
CODEX_TRIGGER=@codex
COPILOT_LABEL=copilot
